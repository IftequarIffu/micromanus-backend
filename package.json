{
  "name": "micromanus-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run dist/index.js",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src db scripts",
    "db:verify": "bun run scripts/verify-supabase.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/google": "^4.0.19",
    "@ai-sdk/openai": "^4.0.16",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@supabase/supabase-js": "^2.90.1",
    "@tavily/core": "^0.7.6",
    "ai": "^7.0.32",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jose": "6.2.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0"
  }
}

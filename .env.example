# Server
PORT=3000

# Supabase (server only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy HS256 JWT secret (Dashboard → Settings → API / JWT). Required when JWKS has no asymmetric keys.
SUPABASE_JWT_SECRET=
# Optional: personal access token for Management API schema apply (not used at runtime)
# SUPABASE_ACCESS_TOKEN=

# Search (system-owned, server only)
TAVILY_API_KEY=

# Stripe (server only). Prefer Test mode keys (sk_test_…) even on Vercel Production
# so dummy cards work. Live keys (sk_live_) are refused unless ALLOW_LIVE_STRIPE=true.
# Local webhook secret: from `stripe listen --forward-to localhost:3000/webhooks/stripe`
# Production: Stripe Dashboard → Test mode → Webhooks → endpoint signing secret
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ALLOW_LIVE_STRIPE=false
# Must include {CHECKOUT_SESSION_ID} in the success URL for Stripe substitution.
# Local:
CHECKOUT_SUCCESS_URL=http://localhost:5173/credits?checkout=success&session_id={CHECKOUT_SESSION_ID}
CHECKOUT_CANCEL_URL=http://localhost:5173/credits?checkout=cancel
# Production (Vercel frontend):
# CHECKOUT_SUCCESS_URL=https://<frontend>.vercel.app/credits?checkout=success&session_id={CHECKOUT_SESSION_ID}
# CHECKOUT_CANCEL_URL=https://<frontend>.vercel.app/credits?checkout=cancel

# Comma-separated frontend origins for CORS (required when frontend and API are on different hosts).
# Local (optional if using Vite proxy): http://localhost:5173
# Production: https://<frontend>.vercel.app
# Include preview origins only if you need them.
CORS_ORIGINS=

# Set automatically via vercel.json for Vercel deploys (do not rely on Bun runtime there):
# VERCEL_EXPERIMENTAL_BACKENDS=1
# VERCEL_ENABLE_EXPERIMENTAL_BUILD_MODE=1

# Master key for BYOK provider API keys (AES-256-GCM). Prefer 64 hex chars or base64 of 32 bytes;
# any other string is hashed with SHA-256. Server only — never commit a real value.
ENCRYPTION_KEY=

# Protects internal/admin routes if added later (server only)
ADMIN_SECRET=

# Note: LLM provider keys (OpenAI / Claude / Gemini) are bring-your-own-key.
# Users store them via POST /api-keys — do not put them in this file.

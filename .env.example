# Server
PORT=3000

# Supabase (server only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy HS256 JWT secret (Dashboard → Settings → API / JWT). Required when JWKS has no asymmetric keys.
SUPABASE_JWT_SECRET=
# Optional: personal access token for Management API schema apply (not used at runtime)
# SUPABASE_ACCESS_TOKEN=

# Search (system-owned, server only)
TAVILY_API_KEY=

# Stripe (server only). Use test keys locally.
# Webhook secret: from `stripe listen --forward-to localhost:3000/webhooks/stripe`
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Must include {CHECKOUT_SESSION_ID} in the success URL for Stripe substitution.
CHECKOUT_SUCCESS_URL=http://localhost:5173/credits?checkout=success&session_id={CHECKOUT_SESSION_ID}
CHECKOUT_CANCEL_URL=http://localhost:5173/credits?checkout=cancel

# Master key for BYOK provider API keys (AES-256-GCM). Prefer 64 hex chars or base64 of 32 bytes;
# any other string is hashed with SHA-256. Server only — never commit a real value.
ENCRYPTION_KEY=

# Protects internal/admin routes if added later (server only)
ADMIN_SECRET=

# Note: LLM provider keys (OpenAI / Claude / Gemini) are bring-your-own-key.
# Users store them via POST /api-keys — do not put them in this file.
